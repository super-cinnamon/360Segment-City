    "version": "0.2.0",
    "configurations": [
        {
            "name": "test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test_random_image.py",
            "console": "integratedTerminal",
            "args": [
                "--image_dir",
                "data/bdd/images/100k/val",
                "--checkpoint_path",
                "./models/latest_checkpoint.pth",
                "--threshold",
                "0.2"
            ]
        },
        {
            "name": "train",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_training.py",
            "console": "integratedTerminal",
            "args": [
                // "--image_dir",
                // "data/bdd/images/100k/train",
                // "--label_dir",
                // "data/bdd/labels/100k/train",
                "--epochs",
                "3",
                "--batch_size",
                "2",
                "--checkpoint_interval",
                "1",
                "--save_path",
                "./checkpoints",
                "--percentage",
                "0.001",
                "--val_percentage",
                "0.001"
            ]
        }
    ]
}